# ─────────────────────────────────────────────────────────────
#  AWS S3 — copy this file to .env.local and fill in real values.
#  NEVER commit .env.local. These keys stay server-side only and
#  are read exclusively inside src/lib/s3.ts / the /api/upload route.
# ─────────────────────────────────────────────────────────────

# Region of your private S3 bucket, e.g. ap-south-1
AWS_REGION=

# Name of the PRIVATE bucket that stores offerings (no public access)
AWS_S3_BUCKET=

# IAM credentials with s3:PutObject on the bucket above
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
