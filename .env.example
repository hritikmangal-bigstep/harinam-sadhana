# ─────────────────────────────────────────────────────────────
#  Copy this file to .env.local and fill in real values.
#  NEVER commit .env.local or any file containing real secrets.
#
#  Deployment split:
#    Frontend (Amplify) — only needs NEXT_PUBLIC_BACKEND_URL
#    Backend            — needs all AWS + Google Sheets vars
#    Local dev          — needs all vars; leave NEXT_PUBLIC_BACKEND_URL
#                         unset so requests hit local Next.js API routes
# ─────────────────────────────────────────────────────────────

# ── Frontend (set in Amplify environment variables) ───────────
# URL of the separately deployed backend. Leave blank in local dev.
NEXT_PUBLIC_BACKEND_URL=

# ── AWS S3 (backend only) ─────────────────────────────────────
# Region of your private S3 bucket, e.g. ap-south-1
AWS_REGION=

# Name of the PRIVATE bucket that stores audio + metadata (no public access)
AWS_S3_BUCKET=

# IAM credentials with s3:PutObject on the bucket above
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Google Sheets (backend only) ─────────────────────────────
# Service account email with Editor access to the sheet
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from the service account JSON — keep newlines as \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# The spreadsheet ID from the Sheets URL
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_ID=
